# Apps Script 편집기 → 배포 → 웹 앱 → URL 복사 (예: https://script.google.com/macros/s/xxxx/exec)
# 스프레드시트 주소(docs.google.com/...) 넣으면 동작하지 않습니다.
GOOGLE_APPS_SCRIPT_WEB_APP_URL=

# Apps Script Code.gs 의 APPS_SCRIPT_SECRET_VALUE 또는 스크립트 속성과 동일한 비밀 문자열
APPS_SCRIPT_SECRET=

# (선택) MY 화면에 시트 ID 표시용 — 연동 필수는 아님
GOOGLE_SHEETS_SPREADSHEET_ID=
